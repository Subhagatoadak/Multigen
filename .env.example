# ─── Required ──────────────────────────────────────────────────────────────────
# OpenAI API key — required for text-to-DSL LLM preprocessing
OPENAI_API_KEY=sk-...

# ─── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BROKER_URL=localhost:9092
FLOW_REQUEST_TOPIC=flow-requests
FLOW_RESPONSE_TOPIC=flow-responses
FLOW_DLQ_TOPIC=flow-dead-letter

# ─── Temporal ──────────────────────────────────────────────────────────────────
TEMPORAL_SERVER_URL=localhost:7233
TEMPORAL_TASK_QUEUE=flow-task-queue

# ─── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017
CAPABILITY_DB_NAME=multigen
CAPABILITY_COLLECTION_NAME=capabilities

# ─── Services ──────────────────────────────────────────────────────────────────
CAPABILITY_SERVICE_URL=http://localhost:8000

# ─── LLM ───────────────────────────────────────────────────────────────────────
LLM_MODEL=gpt-4o

# ─── Metrics ───────────────────────────────────────────────────────────────────
METRICS_PORT=8000

# ─── Tracing (OpenTelemetry) ───────────────────────────────────────────────────
# Set to your OTLP collector endpoint, e.g. http://jaeger:4317
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=multigen-orchestrator

# ─── LlamaIndex (optional) ─────────────────────────────────────────────────────
# Path to document directory for LlamaIndexAgent
LLAMAINDEX_DOCS_PATH=./data/docs
